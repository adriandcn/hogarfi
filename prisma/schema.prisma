generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── BETTER AUTH ────────────────────────

model BetterAuthUser {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime

  sessions    BetterAuthSession[]
  accounts    BetterAuthAccount[]
  members     HouseholdMember[]
  invitesSent Invitation[]

  @@map("better_auth_user")
}

model BetterAuthSession {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      BetterAuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("better_auth_session")
}

model BetterAuthAccount {
  id                    String   @id
  accountId             String
  providerId            String
  userId                String
  user                  BetterAuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("better_auth_account")
}

model BetterAuthVerification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("better_auth_verification")
}

// ─── HOGAR ──────────────────────────────

model Household {
  id        String   @id @default(cuid())
  name      String
  currency  String   @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      HouseholdMember[]
  expenses     Expense[]
  budgets      Budget[]
  goals Goal[]
  invitations  Invitation[]
  subscription Subscription?
}

model HouseholdMember {
  id           String   @id @default(cuid())
  householdId  String
  userId       String?  // null si es miembro sin cuenta aún
  name         String?  // nombre manual hasta que acepte invitación
  role         Role     @default(MEMBER)
  defaultShare Float
  income Float? @default(0)
  joinedAt     DateTime @default(now())
goalContributions GoalContribution[]
  household Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      BetterAuthUser? @relation(fields: [userId], references: [id], onDelete: Cascade)
  splits    ExpenseSplit[]

  @@unique([householdId, userId])
}

enum Role {
  ADMIN
  MEMBER
}

// ─── INVITACIONES ───────────────────────

model Invitation {
  id          String       @id @default(cuid())
  householdId String
  invitedBy   String
  memberId    String?      // HouseholdMember.id al que corresponde
  email       String?
  phone       String?
  token       String       @unique @default(cuid())
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime     @default(now())

  household Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  inviter   BetterAuthUser @relation(fields: [invitedBy], references: [id])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

// ─── GASTOS ─────────────────────────────

model Expense {
  id               String   @id @default(cuid())
  householdId      String
  paidById         String
  description      String
  amount           Float
  categoryId       String?
  useDefaultShares Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  household Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  splits    ExpenseSplit[]
  category  Category?      @relation(fields: [categoryId], references: [id])
}

model ExpenseSplit {
  id         String @id @default(cuid())
  expenseId  String
  memberId   String
  percentage Float
  amount     Float

  expense Expense         @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  member  HouseholdMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

// ─── PRESUPUESTO ────────────────────────

model Category {
  id          String @id @default(cuid())
  householdId String
  name        String
  icon        String @default("📦")
  color       String @default("#6b6b72")

  budgets  Budget[]
  expenses Expense[]
}

model Budget {
  id          String @id @default(cuid())
  householdId String
  categoryId  String
  amount      Float
  month       Int
  year        Int

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([householdId, categoryId, month, year])
}

// ─── SUSCRIPCIÓN ────────────────────────

model Subscription {
  id               String    @id @default(cuid())
  householdId      String    @unique
  plan             Plan      @default(FREE)
  status           SubStatus @default(TRIALING)
  stripeCustomerId String?
  stripeSubId      String?
  trialEndsAt      DateTime?
  currentPeriodEnd DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

enum Plan {
  FREE
  STANDARD
  PREMIUM
}

enum SubStatus {
  TRIALING
  ACTIVE
  CANCELED
  PAST_DUE
}

model Goal {
  id            String              @id @default(cuid())
  householdId   String
  name          String
  icon          String              @default("🎯")
  targetAmount  Float
  currentAmount Float               @default(0)
  monthlyTarget Float               @default(0)
  deadline      DateTime?
  createdAt     DateTime            @default(now())
  household     Household           @relation(fields: [householdId], references: [id])
  contributions GoalContribution[]
}

model GoalContribution {
  id        String   @id @default(cuid())
  goalId    String
  memberId  String
  amount    Float
  note      String?
  createdAt DateTime @default(now())
  goal      Goal     @relation(fields: [goalId], references: [id])
  member    HouseholdMember @relation(fields: [memberId], references: [id])
}